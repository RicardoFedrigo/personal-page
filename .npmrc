# Keep installs deterministic and reduce accidental dependency drift.
save-exact=true
package-lock=true

# Run npm's vulnerability audit automatically on install.
audit=true
audit-level=moderate

# Avoid noisy install output that can hide important security warnings.
fund=false

# Fail installs when peer dependencies are incompatible instead of silently resolving risky trees.
strict-peer-deps=true

# Do not allow npm to fall back to insecure HTTP registry URLs.
strict-ssl=true
